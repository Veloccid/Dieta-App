function mealCard(cat, meal){
  const open = !!state.openCard[cat.id+meal];
  if(cat.always){
    return `<div class="card">
      <div class="cardhead" data-toggle="${cat.id}${meal}">
        <div class="left"><span class="ic-circle">${cat.icon}</span>
          <div><p class="cardtitle">${cat.label}</p><p class="cardsub">Sempre disponibili</p></div>
        </div>
        <span class="chev">${open?"▴":"▾"}</span>
      </div>
      ${open?`<div class="itemlist">${cat.items.map(itemRow).join("")}</div>`:""}
    </div>`;
  }
  const target = TARGETS[cat.id] ? TARGETS[cat.id][meal] : undefined;
  if(target === 0){
    return `<div class="card dim">
      <div class="cardhead"><div class="left"><span class="ic-circle dim">${cat.icon}</span>
        <div><p class="cardtitle" style="color:#a8a29e">${cat.label}</p><p class="cardsub dim">Mai a ${meal}</p></div></div>
      </div></div>`;
  }
  if(target === null || target === undefined){
    return `<div class="card">
      <div class="cardhead" data-toggle="${cat.id}${meal}">
        <div class="left"><span class="ic-circle">${cat.icon}</span>
          <div><p class="cardtitle">${cat.label}</p><p class="cardsub">Sempre disponibili a ${meal}</p></div>
        </div>
        <span class="chev">${open?"▴":"▾"}</span>
      </div>
      ${open?`<div class="itemlist">${cat.items.map(itemRow).join("")}</div>`:""}
    </div>`;
  }
  const count = (state.counts[cat.id] && state.counts[cat.id][meal]) || 0;
  const pct = Math.min(100, (count/target)*100);
  return `<div class="card">
    <div class="cardhead">
      <div class="left"><span class="ic-circle">${cat.icon}</span>
        <div><p class="cardtitle">${cat.label}</p><p class="cardsub muted">${count} / ${target} questa settimana</p></div>
      </div>
      <div class="counters">
        <button class="roundbtn" data-bump="${cat.id}" data-meal="${meal}" data-delta="-1">−</button>
        <button class="roundbtn plus" data-bump="${cat.id}" data-meal="${meal}" data-delta="1">+</button>
      </div>
    </div>
    <div class="progress ${count>=target?'full':''}"><div style="width:${pct}%"></div></div>
    <button class="examplesbtn" data-toggle="${cat.id}${meal}">Esempi alimenti ${open?"▴":"▾"}</button>
    ${open?`<div class="itemlist">${cat.items.map(itemRow).join("")}</div>`:""}
  </div>`;
}

