document.getElementById("content").addEventListener("click", (e)=>{
  const check = e.target.closest("[data-check]");
  if(check){ const k = check.dataset.check; state.checked[k] = !state.checked[k]; render(); return; }

  const setmeal = e.target.closest("[data-setmeal]");
  if(setmeal){ state.meal = setmeal.dataset.setmeal; render(); return; }

  const reset = e.target.closest("[data-reset]");
  if(reset){ state.counts = emptyCounts(); saveStorage(); render(); return; }

  const bump = e.target.closest("[data-bump]");
  if(bump){
    const cat = bump.dataset.bump, meal = bump.dataset.meal, delta = parseInt(bump.dataset.delta,10);
    const cur = (state.counts[cat] && state.counts[cat][meal]) || 0;
    state.counts[cat] = Object.assign({}, state.counts[cat], {[meal]: Math.max(0, cur+delta)});
    saveStorage(); render(); return;
  }

  const toggle = e.target.closest("[data-toggle]");
  if(toggle){
    const k = toggle.dataset.toggle;
    state.openCard[k] = !state.openCard[k];
    render(); return;
  }

  const alimtoggle = e.target.closest("[data-alimtoggle]");
  if(alimtoggle){
    const k = alimtoggle.dataset.alimtoggle;
    state.openAlim[k] = !state.openAlim[k];
    render(); return;
  }

  const altroopen = e.target.closest("[data-altroopen]");
  if(altroopen){ state.altroView = altroopen.dataset.altroopen; render(); return; }

  const altroback = e.target.closest("[data-altroback]");
  if(altroback){ state.altroView = null; render(); return; }

  const pickday = e.target.closest("[data-pickday]");
  if(pickday){ state.spesaDay = parseInt(pickday.dataset.pickday,10); saveSpesaDay(); render(); return; }

  const addgcal = e.target.closest("[data-addgcal]");
  if(addgcal){ openGoogleCalendar(); return; }

  const addics = e.target.closest("[data-addics]");
  if(addics){ downloadICS(); return; }

  const delspesa = e.target.closest("[data-delspesa]");
  if(delspesa){
    const id = delspesa.dataset.delspesa;
    state.spesaItems = state.spesaItems.filter(it=>it.id!==id);
    saveSpesa(); render(); return;
  }

  const checkspesa = e.target.closest("[data-checkspesa]");
  if(checkspesa){
    const id = checkspesa.dataset.checkspesa;
    const it = state.spesaItems.find(x=>x.id===id);
    if(it) it.checked = !it.checked;
    saveSpesa(); render(); return;
  }

  const addspesa = e.target.closest("[data-addspesa]");
  if(addspesa){ addCustomSpesaItem(); return; }

  const resetspesa = e.target.closest("[data-resetspesa]");
  if(resetspesa){ state.spesaItems = freshSpesaItems(); saveSpesa(); render(); return; }
});

document.getElementById("content").addEventListener("input", (e)=>{
  if(e.target.id==="searchbox"){ state.query = e.target.value; render(); }
  if(e.target.id==="spesa-input"){ state.spesaInput = e.target.value; }
});

document.getElementById("content").addEventListener("keydown", (e)=>{
  if(e.target.id==="spesa-input" && e.key==="Enter"){ e.preventDefault(); addCustomSpesaItem(); }
});

render();
</script>
</body>
</html>
