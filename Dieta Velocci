<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
<title>Dieta anti-gonfiore</title>
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="mobile-web-app-capable" content="yes">
<meta name="theme-color" content="#065f46">
<link rel="icon" href="data:,">
<style>
  :root{
    --bg:#f1f0ed; --card:#ffffff; --ink:#1c1917; --ink-soft:#78716c; --line:#e7e5e4;
    --brand:#065f46; --brand-soft:#ecfdf5;
    --ok:#059669; --ok-soft:#ecfdf5;
    --warn:#d97706; --warn-soft:#fffbeb;
    --bad:#e11d48; --bad-soft:#fff1f2;
  }
  *{box-sizing:border-box;}
  body{margin:0;background:var(--bg);font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif;color:var(--ink);}
  .shell{min-height:100vh;display:flex;justify-content:center;}
  .app{width:100%;max-width:440px;background:var(--bg);display:flex;flex-direction:column;min-height:100vh;}
  @media(min-width:480px){ .app{box-shadow:0 0 40px rgba(0,0,0,.08); margin:24px 0; min-height:calc(100vh - 48px); border-radius:28px; overflow:hidden;} }
  header.topbar{display:flex;align-items:center;gap:10px;padding:22px 20px 14px;}
  .logo{width:40px;height:40px;border-radius:50%;background:var(--brand);display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0;}
  h1{font-family:Georgia,serif;font-size:18px;margin:0;letter-spacing:-.2px;line-height:1.2;}
  .eyebrow{font-size:11px;text-transform:uppercase;letter-spacing:.06em;color:var(--ink-soft);margin:2px 0 0;}
  main{flex:1;padding:0 20px 100px;}
  nav.bottomnav{position:sticky;bottom:0;background:var(--bg);border-top:1px solid var(--line);display:flex;justify-content:space-around;padding:8px 10px calc(8px + env(safe-area-inset-bottom));}
  .navbtn{display:flex;flex-direction:column;align-items:center;gap:3px;background:none;border:none;padding:6px 6px;cursor:pointer;color:var(--ink-soft);font-size:10px;}
  .navbtn .ic{width:30px;height:30px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:15px;}
  .navbtn.active{color:var(--brand);font-weight:600;}
  .navbtn.active .ic{background:var(--brand);color:#fff;}

  .segmented{display:inline-flex;background:#fff;border:1px solid var(--line);border-radius:999px;padding:3px;}
  .seg{border:none;background:none;border-radius:999px;padding:7px 14px;font-size:13px;font-weight:500;color:var(--ink-soft);cursor:pointer;}
  .seg.active{background:var(--brand);color:#fff;}
  .toprow{display:flex;align-items:center;justify-content:space-between;margin:14px 0 14px;}
  .resetbtn{border:none;background:none;color:var(--ink-soft);font-size:12px;cursor:pointer;display:flex;align-items:center;gap:4px;}

  .card{background:var(--card);border:1px solid var(--line);border-radius:18px;padding:15px;margin-bottom:12px;}
  .card.dim{background:#ebe9e6;opacity:.65;}
  .cardhead{display:flex;align-items:center;justify-content:space-between;cursor:pointer;}
  .cardhead .left{display:flex;align-items:center;gap:10px;}
  .ic-circle{width:36px;height:36px;border-radius:50%;background:var(--brand-soft);color:var(--brand);display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0;}
  .ic-circle.dim{background:#ddd9d4;color:#a8a29e;}
  .cardtitle{font-family:Georgia,serif;font-size:15px;margin:0;line-height:1.2;}
  .cardsub{font-size:12px;color:var(--ok);margin:2px 0 0;}
  .cardsub.dim{color:#a8a29e;}
  .cardsub.muted{color:var(--ink-soft);}
  .chev{color:#c4c0bb;font-size:13px;}

  .counters{display:flex;align-items:center;gap:6px;}
  .roundbtn{width:28px;height:28px;border-radius:50%;border:1px solid var(--line);background:#fff;color:var(--ink-soft);font-size:15px;display:flex;align-items:center;justify-content:center;cursor:pointer;line-height:0;}
  .roundbtn.plus{background:var(--brand);border-color:var(--brand);color:#fff;}
  .progress{height:6px;background:#efeceA;border-radius:99px;overflow:hidden;margin-top:10px;}
  .progress > div{height:100%;border-radius:99px;background:var(--ok);transition:width .2s;}
  .progress.full > div{background:var(--warn);}
  .examplesbtn{margin-top:10px;border:none;background:none;color:var(--ink-soft);font-size:12px;cursor:pointer;padding:0;}

  .itemlist{margin-top:8px;}
  .item{display:flex;gap:9px;padding:8px 0;border-bottom:1px solid #f2f0ee;align-items:flex-start;}
  .item:last-child{border-bottom:none;}
  .dot{width:8px;height:8px;border-radius:50%;margin-top:5px;flex-shrink:0;}
  .item-name{font-size:13.5px;margin:0;line-height:1.3;}
  .item-note{font-size:11.5px;color:var(--ink-soft);margin:2px 0 0;}
  .item-risk{font-size:11px;font-weight:600;white-space:nowrap;flex-shrink:0;margin-left:auto;padding-left:6px;}

  .search{display:flex;align-items:center;gap:8px;background:#fff;border:1px solid var(--line);border-radius:999px;padding:11px 16px;margin:14px 0;}
  .search input{border:none;outline:none;background:none;font-size:14px;width:100%;color:var(--ink);}
  .rule{display:flex;gap:7px;background:#f7f6f4;border-radius:10px;padding:9px 11px;font-size:12px;color:#57534e;margin-top:10px;}

  .legend{display:flex;flex-wrap:wrap;gap:6px;margin-top:6px;}
  .legendchip{display:flex;align-items:center;gap:6px;border:1px solid var(--line);border-radius:999px;padding:5px 10px;font-size:11px;}

  .alcohead{display:flex;align-items:center;gap:10px;margin-bottom:10px;}
  .alcohead .ic-circle{background:var(--warn-soft);color:var(--warn);}
  .alcolist{margin:0;padding:0;list-style:none;display:flex;flex-direction:column;gap:10px;}
  .alcolist li{display:flex;gap:9px;font-size:13.5px;line-height:1.4;}
  .alcolist b{font-weight:600;}
  .alcosparkle{flex-shrink:0;}
  .greencard{background:var(--ok-soft);border-color:#bbf0d8;}
  .greencard .ic-circle{background:#fff;color:var(--ok);}
  .greencard p.cardtitle{color:#065f46;}
  .greencard .body{color:#065f46;font-size:13.5px;margin:0;}
  .redcard{background:var(--bad-soft);border-color:#fecdd3;}
  .redcard .ic-circle{background:#fff;color:var(--bad);}
  .redcard p.cardtitle{color:#9f1239;}
  .redcard .body{color:#9f1239;font-size:13.5px;margin:0;}
  .footnote{display:flex;gap:7px;color:#a8a29e;font-size:11.5px;padding:4px 4px 18px;}

  .introcard{background:#1c1917;border-radius:18px;padding:16px;margin-bottom:14px;}
  .introcard p{color:#e7e5e4;font-size:13.5px;line-height:1.5;margin:0;}
  .introcard b{color:#fff;}
  .sectionlabel{font-size:11px;text-transform:uppercase;letter-spacing:.05em;color:var(--ink-soft);margin:18px 2px 8px;}
  .checklist{display:flex;flex-direction:column;gap:2px;}
  .check-item{display:flex;align-items:flex-start;gap:10px;padding:9px 2px;cursor:pointer;}
  .check-box{width:20px;height:20px;border-radius:7px;border:1.5px solid #d6d3ce;flex-shrink:0;margin-top:1px;display:flex;align-items:center;justify-content:center;font-size:12px;color:#fff;transition:background .15s;}
  .check-text{font-size:13.5px;line-height:1.4;}
  .check-item.done .check-box{background:var(--brand);border-color:var(--brand);}
  .check-item.done .check-text{color:#a8a29e;text-decoration:line-through;}
  .calmcard{background:var(--ok-soft);border:1px solid #bbf0d8;border-radius:18px;padding:15px;margin-top:16px;}
  .calmcard p{color:#065f46;font-size:13px;line-height:1.5;margin:0;}
  .calmcard .cardtitle{color:#065f46;margin-bottom:6px;}

  .weekrow{display:flex;gap:6px;justify-content:space-between;margin:14px 0 6px;}
  .daychip{flex:1;display:flex;flex-direction:column;align-items:center;gap:2px;border:1px solid var(--line);background:#fff;border-radius:12px;padding:8px 2px;cursor:pointer;}
  .daychip-name{font-size:10px;color:var(--ink-soft);}
  .daychip-num{font-size:13px;font-weight:600;color:var(--ink);}
  .daychip.istoday{border-color:var(--brand);}
  .daychip.picked{background:var(--brand);}
  .daychip.picked .daychip-name, .daychip.picked .daychip-num{color:#fff;}
  .calbuttons{display:flex;flex-direction:column;gap:8px;margin:10px 0 4px;}
  .calbtn{border:none;border-radius:12px;padding:11px;font-size:13px;font-weight:600;background:var(--brand);color:#fff;cursor:pointer;}
  .calbtn.outline{background:#fff;border:1px solid var(--line);color:var(--ink);}
  .addrow{display:flex;gap:8px;margin-top:8px;}
  .addrow input{flex:1;border:1px solid var(--line);border-radius:10px;padding:8px 10px;font-size:13px;outline:none;}
  .addrow button{border:none;background:var(--brand);color:#fff;width:36px;border-radius:10px;font-size:16px;cursor:pointer;}

  .backrow{display:flex;align-items:center;gap:8px;margin:4px 0 14px;cursor:pointer;}
  .backrow .arrow{font-size:15px;color:var(--ink-soft);}
  .backrow .label{font-size:13.5px;color:var(--ink-soft);font-weight:600;}

  .menuitem{display:flex;align-items:center;justify-content:space-between;background:#fff;border:1px solid var(--line);border-radius:16px;padding:14px 15px;margin-bottom:10px;cursor:pointer;}
  .menuitem .left{display:flex;align-items:center;gap:12px;}
  .menutitle{font-family:Georgia,serif;font-size:15px;margin:0;}
  .menusub{font-size:11.5px;color:var(--ink-soft);margin:2px 0 0;}

  .cardbody{font-size:13.5px;line-height:1.55;color:#44403c;margin:8px 0 0;}
  .dosebadge{display:inline-block;background:var(--brand-soft);color:var(--brand);font-size:11px;font-weight:700;padding:3px 10px;border-radius:999px;margin-top:9px;}
  .warnbadge{display:inline-block;background:var(--warn-soft);color:var(--warn);font-size:11px;font-weight:700;padding:3px 10px;border-radius:999px;margin-top:9px;}
  .sourcelist{font-size:10.5px;color:#b5b1ab;line-height:1.7;padding:6px 4px 22px;}

  .delbtn{margin-left:auto;color:#c4c0bb;font-size:14px;padding:2px 4px;flex-shrink:0;}
</style>
</head>
<body>
<div class="shell"><div class="app">
  <header class="topbar">
    <div class="logo">🍽️</div>
    <div>
      <h1>Dieta anti-gonfiore</h1>
      <p class="eyebrow">Consultazione rapida</p>
    </div>
  </header>
  <main id="content"></main>
  <nav class="bottomnav">
    <button class="navbtn" data-tab="oggi"><span class="ic">☀️</span>Oggi</button>
    <button class="navbtn" data-tab="alimenti"><span class="ic">🔍</span>Alimenti</button>
    <button class="navbtn" data-tab="allenamenti"><span class="ic">🏃</span>Corsa</button>
    <button class="navbtn" data-tab="spesa"><span class="ic">🛒</span>Spesa</button>
    <button class="navbtn" data-tab="altro"><span class="ic">⋯</span>Altro</button>
  </nav>
</div></div>

<script>
const RISK = {
  ok: { label: "Via libera", color: "var(--ok)" },
  moderato: { label: "Attenzione", color: "var(--warn)" },
  alto: { label: "Limita/sostituisci", color: "var(--bad)" },
};

const CATEGORIES = [
  { id:"magri", label:"Proteici magri", icon:"🥚", items:[
    {name:"Affettato vegetale", risk:"moderato", note:"Scegli marche senza cipolla/aglio in polvere"},
    {name:"Pasta di piselli", risk:"ok", note:"Porzione standard ok"},
    {name:"Lupini", risk:"alto", note:"Porzioni piccole, non abituali"},
    {name:"Nuggets / burger vegani", risk:"moderato", note:"Niente cipolla/aglio in polvere in etichetta"},
    {name:"Cacioricotta, Feta", risk:"ok", note:"Porzioni standard ok"},
    {name:"Fiocchi di formaggio, Ricotta", risk:"alto", note:"Versione delattosata o porzione piccola"},
  ]},
  { id:"grassi", label:"Proteici grassi", icon:"🧀", items:[
    {name:"Uova", risk:"ok", note:"Libere, nessuna restrizione"},
    {name:"Tofu compatto", risk:"ok", note:"Da preferire"},
    {name:"Burger di soia", risk:"moderato", note:"Controlla cipolla/aglio/frumento"},
    {name:"Brie, Camembert", risk:"ok", note:"Stagionati/erborinati: lattosio già ridotto"},
    {name:"Mozzarella di bufala", risk:"alto", note:"Riduci porzione o alterna con stagionati"},
    {name:"Caciotta, Scamorza", risk:"moderato", note:"Porzioni standard ok"},
    {name:"Crescenza, Stracchino", risk:"alto", note:"Riduci / alterna con stagionati"},
    {name:"Taleggio", risk:"moderato", note:"Ok"},
    {name:"Parmigiano, Grana, Pecorino stag., Emmenthal stag., Caciocavallo, Burrino", risk:"ok", note:"Da preferire sempre"},
  ]},
  { id:"legumi", label:"Legumi", icon:"🫘",
    rule:"Porzione: 30-40g sgocciolati, in scatola e ben sciacquati. Mai due legumi diversi nello stesso pasto.",
    items:[
      {name:"Lenticchie", risk:"ok", note:"Le più digeribili della scala"},
      {name:"Piselli", risk:"ok", note:""},
      {name:"Ceci", risk:"moderato", note:"Max 30-40g sgocciolati"},
      {name:"Fagioli, cannellini, fave", risk:"alto", note:"Le meno digeribili, porzioni piccole"},
    ]},
  { id:"grassiveg", label:"Grassi vegetali", icon:"🫒", always:true, items:[
    {name:"Avocado 35g", risk:"moderato", note:"Non aumentare la porzione"},
    {name:"Burro di arachidi 15g", risk:"ok", note:"Libero"},
    {name:"Hummus 30g", risk:"moderato", note:"Preferisci homemade senza aglio"},
    {name:"Olio 10g", risk:"ok", note:"Libero"},
    {name:"Olive 30g", risk:"ok", note:"Non marinate con aglio"},
    {name:"Sughi grassi 15g", risk:"alto", note:"Solo homemade, senza cipolla/aglio fresco"},
  ]},
  { id:"condimenti", label:"Condimenti magri", icon:"🧂", always:true, items:[
    {name:"Aceto, limone", risk:"ok", note:"Liberi"},
    {name:"Salsa di soia / tamari", risk:"ok", note:"Preferisci il tamari (senza glutine)"},
    {name:"Spezie pure", risk:"ok", note:"No ai mix con cipolla/aglio in polvere"},
    {name:"Salsa BBQ industriale", risk:"alto", note:"Quasi sempre cipolla/aglio + sciroppo: fattela in casa"},
  ]},
  { id:"cereali", label:"Cereali", icon:"🌾", items:[
    {name:"Pane 100g", risk:"moderato", note:"Preferisci lievitazione naturale (lievito madre)"},
    {name:"Pasta 85g", risk:"ok", note:"Porzione standard ok"},
    {name:"Piadina", risk:"moderato", note:"Stessa attenzione del pane"},
    {name:"Patate 350g", risk:"ok", note:"Ottime, libere"},
    {name:"Riso 90g", risk:"ok", note:"Ottimo, libero"},
  ]},
  { id:"verdure", label:"Verdure", icon:"🥬", always:true, items:[
    {name:"Zucchine, carote, patate", risk:"ok", note:"Sempre"},
    {name:"Lattuga, insalata, spinaci", risk:"ok", note:"Sempre"},
    {name:"Cetrioli, peperoni, melanzane", risk:"ok", note:"Sempre"},
    {name:"Pomodori", risk:"moderato", note:"Porzione moderata"},
    {name:"Finocchi, fagiolini, zucca", risk:"moderato", note:"Porzione piccola"},
    {name:"Cipolla, aglio (anche in polvere)", risk:"alto", note:"Evita sempre, in ogni forma"},
    {name:"Porro, cavolfiore, funghi, carciofi", risk:"alto", note:"Limita / evita"},
    {name:"Asparagi, cavolo, verza, broccoli", risk:"alto", note:"Ok solo in porzioni piccole"},
  ]},
];

const TARGETS = {
  magri:{pranzo:4,cena:3}, grassi:{pranzo:0,cena:3}, legumi:{pranzo:3,cena:0}, cereali:{pranzo:4,cena:null},
};

const SPESA_BASE = [
  {id:"uova", name:"Uova", cat:"Proteine"},
  {id:"tofu", name:"Tofu compatto", cat:"Proteine"},
  {id:"parmigiano", name:"Parmigiano o Grana", cat:"Proteine"},
  {id:"feta", name:"Feta o Cacioricotta", cat:"Proteine"},
  {id:"pecorino", name:"Formaggio stagionato (Pecorino/Caciocavallo)", cat:"Proteine"},
  {id:"lenticchie", name:"Lenticchie in scatola", cat:"Legumi"},
  {id:"piselli", name:"Piselli in scatola", cat:"Legumi"},
  {id:"riso", name:"Riso", cat:"Cereali"},
  {id:"patate", name:"Patate", cat:"Cereali"},
  {id:"pasta", name:"Pasta", cat:"Cereali"},
  {id:"pane", name:"Pane a lievitazione naturale", cat:"Cereali"},
  {id:"zucchine", name:"Zucchine", cat:"Verdure"},
  {id:"carote", name:"Carote", cat:"Verdure"},
  {id:"insalata", name:"Insalata o spinaci", cat:"Verdure"},
  {id:"cetrioli", name:"Cetrioli", cat:"Verdure"},
  {id:"peperoni", name:"Peperoni", cat:"Verdure"},
  {id:"melanzane", name:"Melanzane", cat:"Verdure"},
  {id:"olio", name:"Olio EVO", cat:"Grassi e condimenti"},
  {id:"olive", name:"Olive", cat:"Grassi e condimenti"},
  {id:"burroarachidi", name:"Burro di arachidi", cat:"Grassi e condimenti"},
  {id:"limone", name:"Limone", cat:"Grassi e condimenti"},
];
const SPESA_CAT_ORDER = ["Proteine","Legumi","Cereali","Verdure","Grassi e condimenti","Altro"];
const DAY_NAMES = ["Lun","Mar","Mer","Gio","Ven","Sab","Dom"];
const DAY_ICS = ["MO","TU","WE","TH","FR","SA","SU"];

function freshSpesaItems(){
  return SPESA_BASE.map(it=>Object.assign({checked:false,custom:false}, it));
}
function todayIndex(){ const day = new Date().getDay(); return day===0?6:day-1; }
function getWeekDates(d){
  d = d || new Date();
  const date = new Date(d.getTime()); date.setHours(0,0,0,0);
  const idx = date.getDay()===0?6:date.getDay()-1;
  const monday = new Date(date); monday.setDate(date.getDate()-idx);
  const days = [];
  for(let i=0;i<7;i++){ const d2=new Date(monday); d2.setDate(monday.getDate()+i); days.push(d2); }
  return days;
}
function nextOccurrence(dayIndex){
  const weekDates = getWeekDates();
  const target = new Date(weekDates[dayIndex]);
  target.setHours(18,0,0,0);
  if(target.getTime() < new Date().getTime()) target.setDate(target.getDate()+7);
  return target;
}
function pad(n){ return n<10? "0"+n : ""+n; }
function fmtCal(d){ return d.getFullYear()+pad(d.getMonth()+1)+pad(d.getDate())+"T"+pad(d.getHours())+pad(d.getMinutes())+"00"; }
function escapeICS(text){ return String(text).replace(/\\/g,"\\\\").replace(/;/g,"\\;").replace(/,/g,"\\,").replace(/\n/g,"\\n"); }
function spesaListText(){
  const grouped = {};
  state.spesaItems.forEach(it=>{ (grouped[it.cat]=grouped[it.cat]||[]).push(it.name); });
  return SPESA_CAT_ORDER.filter(c=>grouped[c]&&grouped[c].length).map(c=>c+": "+grouped[c].join(", ")).join("\n");
}
function openGoogleCalendar(){
  const start = nextOccurrence(state.spesaDay);
  const end = new Date(start.getTime()+30*60000);
  const params = new URLSearchParams({
    action:"TEMPLATE",
    text:"Spesa settimanale 🛒",
    dates: fmtCal(start)+"/"+fmtCal(end),
    details: spesaListText(),
    recur: "RRULE:FREQ=WEEKLY;BYDAY="+DAY_ICS[state.spesaDay],
  });
  window.open("https://calendar.google.com/calendar/render?"+params.toString(), "_blank");
}
function downloadICS(){
  const start = nextOccurrence(state.spesaDay);
  const end = new Date(start.getTime()+30*60000);
  const now = new Date();
  const stamp = now.getFullYear()+pad(now.getMonth()+1)+pad(now.getDate())+"T"+pad(now.getHours())+pad(now.getMinutes())+pad(now.getSeconds())+"Z";
  const uid = "spesa-"+Date.now()+"@dieta-antigonfiore";
  const ics = [
    "BEGIN:VCALENDAR","VERSION:2.0","PRODID:-//Dieta anti-gonfiore//IT","CALSCALE:GREGORIAN",
    "BEGIN:VEVENT","UID:"+uid,"DTSTAMP:"+stamp,"DTSTART:"+fmtCal(start),"DTEND:"+fmtCal(end),
    "RRULE:FREQ=WEEKLY;BYDAY="+DAY_ICS[state.spesaDay],
    "SUMMARY:Spesa settimanale","DESCRIPTION:"+escapeICS(spesaListText()),
    "END:VEVENT","END:VCALENDAR"
  ].join("\r\n");
  const blob = new Blob([ics], {type:"text/calendar;charset=utf-8"});
  const url = URL.createObjectURL(blob);
  const a = document.createElement("a");
  a.href = url; a.download = "spesa-settimanale.ics";
  document.body.appendChild(a); a.click(); document.body.removeChild(a);
  setTimeout(()=>URL.revokeObjectURL(url), 2000);
}

function getWeekKey(d){
  d = d || new Date();
  const date = new Date(d.getTime()); date.setHours(0,0,0,0);
  const jan1 = new Date(date.getFullYear(),0,1);
  const days = Math.floor((date - jan1)/86400000);
  const week = Math.ceil((days + jan1.getDay() + 1)/7);
  return date.getFullYear()+"-W"+week;
}
function emptyCounts(){ return {magri:{pranzo:0,cena:0},grassi:{pranzo:0,cena:0},legumi:{pranzo:0,cena:0},cereali:{pranzo:0,cena:0}}; }

let state = {
  tab:"oggi",
  meal: (new Date().getHours() < 15 ? "pranzo" : "cena"),
  counts: emptyCounts(),
  query:"",
  openAlim: {}, // accordion state Alimenti tab
  openCard: {}, // "esempi" expand state Oggi tab
  checked: {}, // checklist Recupero tab (solo in sessione, non persistito)
  spesaItems: freshSpesaItems(),
  spesaDay: todayIndex(),
  spesaInput: "",
  altroView: null, // null | "alcol" | "recupero" | "integratori"
};

(function loadStorage(){
  try{
    const raw = localStorage.getItem("dieta-tracker-v1");
    if(raw){
      const data = JSON.parse(raw);
      if(data.weekKey === getWeekKey() && data.counts){
        state.counts = Object.assign(emptyCounts(), data.counts);
        return;
      }
    }
  }catch(e){}
  saveStorage();
})();
function saveStorage(){
  try{ localStorage.setItem("dieta-tracker-v1", JSON.stringify({weekKey:getWeekKey(), counts:state.counts})); }catch(e){}
}

(function loadSpesa(){
